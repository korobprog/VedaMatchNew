generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
  service_admin
}

enum ServiceStatus {
  active
  coming_soon
  disabled
}

enum SpiritualStage {
  seeker
  practitioner
  yogi
  devotee
}

enum DevoteeVerificationStatus {
  self_identified
  awaiting_mentor
  mentor_submitted
  awaiting_admin
  confirmed
  rejected
  needs_clarification
}

enum StageChangeActor {
  system
  user
  admin
}

model User {
  id                         String                      @id @default(uuid())
  email                      String                      @unique
  name                       String
  avatarUrl                  String?
  avatarKey                  String?
  homeLocation               Json?
  socialLinks                Json?
  messengers                 Json?
  role                       Role                        @default(user)
  googleId                   String?                     @unique
  spiritualStage             SpiritualStage?
  devoteeVerificationStatus  DevoteeVerificationStatus?
  lastSelfIdentificationAt   DateTime?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  refreshTokens              RefreshToken[]
  serviceAccess              ServiceAccess[]
  loginAudits                LoginAudit[]
  selfIdentificationResponses SelfIdentificationResponse[]
  stageHistory               StageHistory[]
  mentorVerificationRequests MentorVerificationRequest[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Service {
  id                           String        @id @default(uuid())
  slug                         String        @unique
  name                         String
  description                  String
  iconUrl                      String?
  url                          String
  status                       ServiceStatus @default(coming_soon)
  category                     String
  // null/true = РЎРғР ВөРЎРӮР РҶР С‘РЎРғ Р Т‘Р С•РЎРғРЎвҖҡРЎС“Р С—Р ВөР Р… Р РҶРЎРғР ВөР Сҳ Р В°Р РҶРЎвҖҡР С•РЎРӮР С‘Р В·Р С•Р РҶР В°Р Р…Р Р…РЎвҖ№Р Сҳ; Р С‘Р Р…Р В°РЎвҖЎР Вө Р Т‘Р С•РЎРғРЎвҖҡРЎС“Р С— РЎвҖЎР ВөРЎРӮР ВөР В· ServiceAccess/РЎРӮР С•Р В»РЎРҠ/РЎРҢРЎвҖҡР В°Р С— Р С—Р С•Р В»РЎРҠР В·Р С•Р РҶР В°РЎвҖҡР ВөР В»РЎРҸ
  public                       Boolean       @default(true)
  seekerVisible                Boolean       @default(true)
  practitionerVisible          Boolean       @default(true)
  yogiVisible                  Boolean       @default(true)
  devoteeSelfIdentifiedVisible Boolean       @default(false)
  devoteeVerifiedVisible       Boolean       @default(false)
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt

  access ServiceAccess[]
}

model ServiceAccess {
  userId    String
  serviceId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([userId, serviceId])
}

model LoginAudit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model SelfIdentificationResponse {
  id                 String                      @id @default(uuid())
  userId             String
  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers            Json
  detectedStage      SpiritualStage
  verificationStatus DevoteeVerificationStatus?
  createdAt          DateTime                    @default(now())

  @@index([userId, createdAt])
}

model StageHistory {
  id                 String                     @id @default(uuid())
  userId             String
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  oldStage           SpiritualStage?
  newStage           SpiritualStage
  actor              StageChangeActor
  reason             String?
  answers            Json?
  verificationStatus DevoteeVerificationStatus?
  mentorRequestId    String?
  createdAt          DateTime                   @default(now())

  @@index([userId, createdAt])
}

model MentorVerificationRequest {
  id                                  String                      @id @default(uuid())
  token                               String                      @unique
  userId                              String
  user                                User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                              DevoteeVerificationStatus   @default(awaiting_mentor)
  mentorName                          String?
  phone                               String?
  email                               String?
  cityOrCommunity                     String?
  knownDuration                       String?
  knowsPersonally                     Boolean?
  confirmsRegularPractice             Boolean?
  confirmsService                     Boolean?
  confirmsSpiritualName               Boolean?
  confirmsCommunityConnection         Boolean?
  userCharacterReference              String?
  recommendsDevoteeStatus             Boolean?
  truthConsent                        Boolean?
  mentorSubmittedAt                   DateTime?
  adminNote                           String?
  adminReviewedAt                     DateTime?
  createdAt                           DateTime                    @default(now())
  updatedAt                           DateTime                    @updatedAt

  @@index([userId, status])
}
