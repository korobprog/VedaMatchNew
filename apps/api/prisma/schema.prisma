generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
  service_admin
}

enum ServiceStatus {
  active
  coming_soon
  disabled
}

enum SpiritualStage {
  seeker
  practitioner
  yogi
  devotee
}

enum DevoteeVerificationStatus {
  self_identified
  awaiting_mentor
  mentor_submitted
  awaiting_admin
  confirmed
  rejected
  needs_clarification
}

enum StageChangeActor {
  system
  user
  admin
}

enum GitabaseAnnotationKind {
  highlight
  note
}

enum VedabaseImportStatus {
  staging
  validated
  active
  failed
}

enum MotivationProfileType {
  user
  in_goodness
  yogi
  devotee
}

enum MotivationAudienceTrack {
  universal
  vaishnava
}

enum MotivationPostStatus {
  draft
  generating
  published
  failed
  hidden
}

enum MotivationAttributionKind {
  exact_quote
  faithful_paraphrase
  ai_reflection
}

enum MotivationReviewStatus {
  discovered
  source_verified
  text_review
  image_queued
  image_review
  published
  rejected
  failed
}

enum MotivationQuoteSourceType {
  vedamatch_library
  approved_web
}

enum MotivationTranslationKind {
  official
  vedamatch
}

enum MotivationVisualStyle {
  spiritual_watercolor
  cinematic_nature
  indian_miniature
  sacred_architecture
  minimal_symbolism
  warm_documentary
  cosmic_contemplation
  historical_editorial
}

model User {
  id                        String                     @id @default(uuid())
  email                     String                     @unique
  name                      String
  avatarUrl                 String?
  avatarKey                 String?
  homeLocation              Json?
  socialLinks               Json?
  messengers                Json?
  role                      Role                       @default(user)
  googleId                  String?                    @unique
  spiritualStage            SpiritualStage?
  devoteeVerificationStatus DevoteeVerificationStatus?
  lastSelfIdentificationAt  DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  refreshTokens               RefreshToken[]
  serviceAccess               ServiceAccess[]
  loginAudits                 LoginAudit[]
  selfIdentificationResponses SelfIdentificationResponse[]
  stageHistory                StageHistory[]
  mentorVerificationRequests  MentorVerificationRequest[]
  unionProfile                UnionProfile?
  unionRequestsSent           UnionConnectionRequest[]     @relation("UnionRequestsSent")
  unionRequestsReceived       UnionConnectionRequest[]     @relation("UnionRequestsReceived")
  unionChatMessagesSent       UnionChatMessage[]           @relation("UnionChatMessagesSent")
  photos                      UserPhoto[]
  gitabaseReadingProgress     GitabaseReadingProgress[]
  gitabaseBookmarks           GitabaseBookmark[]
  gitabaseAnnotations         GitabaseAnnotation[]
  gitabaseSyncMutations       GitabaseSyncMutation[]
  motivationPreference        MotivationPreference?
  motivationFavorites         MotivationFavorite[]
  motivationViews             MotivationView[]
  motivationModerationAudits  MotivationModerationAudit[]
  motivationAuthorWatches     MotivationAuthorWatch[]
  motivationSourceWatches     MotivationSourceWatch[]
}

model UserPhoto {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storageKey String   @unique
  sizeBytes  Int
  width      Int
  height     Int
  isPublic   Boolean  @default(false)
  sortOrder  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, sortOrder, createdAt])
  @@index([userId, isPublic, sortOrder])
}

model MotivationQuote {
  id                  String                       @id @default(uuid())
  originalText        String
  normalizedHash      String                       @unique
  originalLanguage    String                       @db.VarChar(8)
  author              String
  work                String
  locator             String
  sourceType          MotivationQuoteSourceType
  sourceUrl           String?
  vedabaseBookSlug    String?
  vedabaseChapterSlug String?
  contextExcerpt      String
  verified            Boolean                      @default(false)
  verifiedAt          DateTime?
  discoveryDate       DateTime?                    @db.Date
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  translations        MotivationQuoteTranslation[]
  profiles            MotivationQuoteProfile[]
  posts               MotivationPost[]

  @@index([verified, createdAt])
  @@index([sourceType, verified])
  @@index([discoveryDate, verified])
}

model MotivationQuoteTranslation {
  id              String                    @id @default(uuid())
  quoteId         String
  quote           MotivationQuote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  language        String                    @db.VarChar(8)
  quoteText       String
  translationKind MotivationTranslationKind
  label           String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([quoteId, language])
  @@index([language])
}

model MotivationQuoteProfile {
  quoteId     String
  quote       MotivationQuote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  profileType MotivationProfileType
  createdAt   DateTime              @default(now())

  @@id([quoteId, profileType])
  @@index([profileType])
}

model MotivationPost {
  id                   String                    @id @default(uuid())
  contentDate          DateTime                  @db.Date
  profileType          MotivationProfileType
  audienceTrack        MotivationAudienceTrack
  slug                 String                    @unique
  category             String
  quoteId              String?                    @unique
  quote                MotivationQuote?          @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  status               MotivationPostStatus      @default(draft)
  reviewStatus         MotivationReviewStatus    @default(discovered)
  visualStyle          MotivationVisualStyle?
  imagePrompt          String?
  textApprovedAt       DateTime?
  imageApprovedAt      DateTime?
  imageUrl             String?
  storyImageUrl        String?
  attributionKind      MotivationAttributionKind @default(ai_reflection)
  attributionSpeaker   String?
  attributionWork      String?
  attributionLocator   String?
  attributionSourceUrl String?
  sourceVerified       Boolean                   @default(false)
  generationStage      String?
  generationErrorCode  String?
  promptVersion        String?
  modelVersion         String?
  attemptCount         Int                       @default(0)
  estimatedCostUsd     Decimal                   @default(0) @db.Decimal(12, 6)
  publishedAt          DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  translations     MotivationPostTranslation[]
  favorites        MotivationFavorite[]
  views            MotivationView[]
  moderationAudits MotivationModerationAudit[]

  @@index([profileType, audienceTrack, status, publishedAt])
  @@index([category, status, publishedAt])
  @@index([reviewStatus, createdAt])
  @@index([quoteId])
}

model MotivationModerationAudit {
  id        String         @id @default(uuid())
  postId    String
  post      MotivationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User           @relation(fields: [actorId], references: [id], onDelete: Restrict)
  action    String
  reason    String?
  metadata  Json?
  createdAt DateTime       @default(now())

  @@index([postId, createdAt])
  @@index([actorId, createdAt])
}

model MotivationPostTranslation {
  id        String         @id @default(uuid())
  postId    String
  post      MotivationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  language  String         @db.VarChar(8)
  title     String
  text      String
  storyText String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([postId, language])
  @@index([language])
}

model MotivationPreference {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vaishnavaPercent Int      @default(50)
  language         String   @default("ru") @db.VarChar(8)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model MotivationFavorite {
  userId    String
  postId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      MotivationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@id([userId, postId])
  @@index([userId, createdAt])
}

model MotivationView {
  userId   String
  postId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post     MotivationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  viewedAt DateTime       @default(now())

  @@id([userId, postId])
  @@index([userId, viewedAt])
}

model MotivationAuthorWatch {
  id              String    @id @default(uuid())
  name            String
  language        String?   @db.VarChar(8)
  enabled         Boolean   @default(true)
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime  @default(now())
  lastSearchedAt  DateTime?
  lastResultCount Int       @default(0)

  @@unique([name])
}

model MotivationSourceWatch {
  id              String    @id @default(uuid())
  url             String
  label           String?
  enabled         Boolean   @default(true)
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime  @default(now())
  lastFetchedAt   DateTime?
  lastResultCount Int       @default(0)

  @@unique([url])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Service {
  id                           String        @id @default(uuid())
  slug                         String        @unique
  name                         String
  description                  String
  iconUrl                      String?
  url                          String
  status                       ServiceStatus @default(coming_soon)
  category                     String
  // null/true = СЃРµСЂРІРёСЃ РґРѕСЃС‚СѓРїРµРЅ РІСЃРµРј Р°РІС‚РѕСЂРёР·РѕРІР°РЅРЅС‹Рј; РёРЅР°С‡Рµ РґРѕСЃС‚СѓРї С‡РµСЂРµР· ServiceAccess/СЂРѕР»СЊ/СЌС‚Р°Рї РїРѕР»СЊР·РѕРІР°С‚РµР»СЏ
  public                       Boolean       @default(true)
  seekerVisible                Boolean       @default(true)
  practitionerVisible          Boolean       @default(true)
  yogiVisible                  Boolean       @default(true)
  devoteeSelfIdentifiedVisible Boolean       @default(false)
  devoteeVerifiedVisible       Boolean       @default(false)
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt

  access ServiceAccess[]
}

model ServiceAccess {
  userId    String
  serviceId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([userId, serviceId])
}

model LoginAudit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model SelfIdentificationResponse {
  id                 String                     @id @default(uuid())
  userId             String
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers            Json
  detectedStage      SpiritualStage
  verificationStatus DevoteeVerificationStatus?
  createdAt          DateTime                   @default(now())

  @@index([userId, createdAt])
}

model StageHistory {
  id                 String                     @id @default(uuid())
  userId             String
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  oldStage           SpiritualStage?
  newStage           SpiritualStage
  actor              StageChangeActor
  reason             String?
  answers            Json?
  verificationStatus DevoteeVerificationStatus?
  mentorRequestId    String?
  createdAt          DateTime                   @default(now())

  @@index([userId, createdAt])
}

model MentorVerificationRequest {
  id                          String                    @id @default(uuid())
  token                       String                    @unique
  userId                      String
  user                        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                      DevoteeVerificationStatus @default(awaiting_mentor)
  mentorName                  String?
  phone                       String?
  email                       String?
  cityOrCommunity             String?
  knownDuration               String?
  knowsPersonally             Boolean?
  confirmsRegularPractice     Boolean?
  confirmsService             Boolean?
  confirmsSpiritualName       Boolean?
  confirmsCommunityConnection Boolean?
  userCharacterReference      String?
  recommendsDevoteeStatus     Boolean?
  truthConsent                Boolean?
  mentorSubmittedAt           DateTime?
  adminNote                   String?
  adminReviewedAt             DateTime?
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt

  @@index([userId, status])
}

// ===== Gitabase user state =====

model GitabaseReadingProgress {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookSlug   String
  locator    Json
  percentage Int
  lastReadAt DateTime @default(now())
  revision   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([userId, bookSlug])
  @@index([userId, updatedAt])
}

model GitabaseBookmark {
  id        String    @id
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookSlug  String
  locator   Json
  label     String?
  revision  Int       @default(1)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, bookSlug])
  @@index([userId, updatedAt])
}

model GitabaseAnnotation {
  id        String                 @id
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookSlug  String
  kind      GitabaseAnnotationKind
  locator   Json
  range     Json
  color     String?
  noteText  String?
  revision  Int                    @default(1)
  deletedAt DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  revisions GitabaseAnnotationRevision[]

  @@index([userId, bookSlug])
  @@index([userId, updatedAt])
}

model GitabaseAnnotationRevision {
  id           String             @id @default(uuid())
  annotationId String
  annotation   GitabaseAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  revision     Int
  noteText     String?
  createdAt    DateTime           @default(now())

  @@unique([annotationId, revision])
}

model GitabaseSyncMutation {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientMutationId String
  entity           String
  entityId         String
  revision         Int
  payload          Json
  createdAt        DateTime @default(now())

  @@unique([userId, clientMutationId])
  @@index([userId, createdAt, id])
}

// ===== Vedabase canonical content =====

model VedabaseBook {
  id              String                @id @default(uuid())
  slug            String                @unique
  title           String
  author          String?
  language        String
  cover           Json?
  sourceUrl       String
  attribution     String
  activeVersionId String?               @unique
  activeVersion   VedabaseBookVersion?  @relation("ActiveVedabaseVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  versions        VedabaseBookVersion[] @relation("VedabaseBookVersions")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model VedabaseBookVersion {
  id                  String               @id @default(uuid())
  bookId              String
  book                VedabaseBook         @relation("VedabaseBookVersions", fields: [bookId], references: [id], onDelete: Cascade)
  activeFor           VedabaseBook?        @relation("ActiveVedabaseVersion")
  contentVersion      String
  formatVersion       Int
  status              VedabaseImportStatus @default(staging)
  permissionRef       String
  attribution         String
  importedAt          DateTime
  sizeBytes           BigInt
  packageChecksum     String
  chapterCount        Int
  searchableUnitCount Int
  searchIndexBytes    Int
  searchIndexSha256   String
  coverBytes          Int?
  coverSha256         String?
  errorMessage        String?
  chapters            VedabaseChapter[]
  searchUnits         VedabaseSearchUnit[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([bookId, contentVersion])
  @@index([status, updatedAt])
}

model VedabaseChapter {
  id        String              @id @default(uuid())
  versionId String
  version   VedabaseBookVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  slug      String
  title     String
  order     Int
  payload   Json
  bytes     Int
  sha256    String

  @@unique([versionId, slug])
  @@unique([versionId, order])
}

model VedabaseSearchUnit {
  id          String              @id @default(uuid())
  versionId   String
  version     VedabaseBookVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  chapterSlug String
  locator     Json
  title       String
  text        String

  @@index([versionId, chapterSlug])
}

// ===== Union service =====
// Модели сервиса VedaMatch Union. Связи только с User (read-only портальные данные).
// См. docs/service-module-contract.md

enum UnionIntentionType {
  family
  business
  friendship
  service
}

enum UnionConnectionStatus {
  pending
  accepted
  declined
  cancelled
}

enum UnionFormat {
  online
  offline
  any
}

model UnionProfile {
  id              String      @id @default(uuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  about           String?
  relocationReady Boolean     @default(false)
  format          UnionFormat @default(any)
  languages       String[]    @default([])
  skills          String[]    @default([])
  interests       String[]    @default([])
  values          String[]    @default([])
  familyStatus    String?
  // { photo, age, city, contacts: 'everyone' | 'after_match' | 'hidden' }
  privacy         Json?
  // скрыть из рекомендаций без удаления профиля
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  intentions UnionIntention[]
}

model UnionIntention {
  id        String             @id @default(uuid())
  profileId String
  profile   UnionProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type      UnionIntentionType
  // 0..100, сумма по профилю = 100 (валидируется в сервисе)
  weight    Int

  @@unique([profileId, type])
}

model UnionConnectionRequest {
  id          String                @id @default(uuid())
  fromUserId  String
  fromUser    User                  @relation("UnionRequestsSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User                  @relation("UnionRequestsReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  status      UnionConnectionStatus @default(pending)
  message     String?
  createdAt   DateTime              @default(now())
  respondedAt DateTime?

  messages UnionChatMessage[]

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
}

model UnionChatMessage {
  id         String                 @id @default(uuid())
  requestId  String
  request    UnionConnectionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User                   @relation("UnionChatMessagesSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  body       String
  createdAt  DateTime               @default(now())

  @@index([requestId, createdAt])
  @@index([fromUserId])
}
