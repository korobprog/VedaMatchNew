# PostgreSQL
POSTGRES_USER=vedamatch
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vedamatch
DATABASE_URL=postgresql://vedamatch:change-me@localhost:5432/vedamatch

# API
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
# Base URL по которому доступен api снаружи (для OAuth redirect_uri)
API_PUBLIC_URL=http://localhost:4000
COOKIE_DOMAIN=
# Import-only metadata. Supply exact approved values; never invent or infer them.
VEDABASE_SOURCE_PERMISSION_REF=
VEDABASE_SOURCE_ATTRIBUTION=
VEDABASE_CACHE_DIR=.vedabase-cache

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT: RS256 приватный ключ в PKCS8 PEM, base64-encoded одной строкой.
# Сгенерировать: node apps/api/scripts/generate-keys.mjs
JWT_PRIVATE_KEY_BASE64=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000

# Profile avatar storage (S3/S3-compatible)
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=
USER_GALLERY_QUOTA_MB=250

# Optional custom User-Agent for OpenStreetMap Nominatim requests
NOMINATIM_USER_AGENT=VedaMatch/1.0 (profile geo search)
