# PostgreSQL
POSTGRES_USER=vedamatch
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vedamatch
DATABASE_URL=postgresql://vedamatch:change-me@localhost:5432/vedamatch

# API
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
# Base URL по которому доступен api снаружи (для OAuth redirect_uri)
API_PUBLIC_URL=http://localhost:4000
COOKIE_DOMAIN=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT: RS256 приватный ключ в PKCS8 PEM, base64-encoded одной строкой.
# Сгенерировать: node apps/api/scripts/generate-keys.mjs
JWT_PRIVATE_KEY_BASE64=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000
